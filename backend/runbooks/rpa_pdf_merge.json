{
  "id": "rpa_pdf_merge",
  "name": "PDF 合并",
  "description": "将多个 PDF 文件合并为一个，按指定顺序输出。依赖 qpdf 或 ghostscript（会自动检测并安装）。",
  "category": "pdf",
  "tags": ["PDF", "合并", "merge", "文档"],
  "inputs": [
    {"name": "input_files", "type": "string", "required": true, "description": "要合并的 PDF 文件路径，空格分隔，如 a.pdf b.pdf c.pdf"},
    {"name": "output_file", "type": "string", "default": "merged.pdf", "description": "输出文件路径"}
  ],
  "outputs": [
    {"name": "output_file", "description": "合并后的 PDF 路径"}
  ],
  "prerequisites": ["qpdf 或 ghostscript（自动安装）"],
  "steps": [
    {
      "id": "step_1",
      "name": "检查 qpdf",
      "description": "检测 qpdf 是否可用",
      "tool": "terminal",
      "command": "which qpdf && echo 'qpdf_available'",
      "on_error": "fallback",
      "fallback_step": "step_1b",
      "retry": 0
    },
    {
      "id": "step_1b",
      "name": "安装 qpdf",
      "description": "通过 Homebrew 安装 qpdf",
      "tool": "terminal",
      "command": "brew install qpdf && echo '安装完成'",
      "on_error": "fallback",
      "fallback_step": "step_2_gs",
      "retry": 0
    },
    {
      "id": "step_2",
      "name": "使用 qpdf 合并 PDF",
      "description": "用 qpdf 按顺序合并多个 PDF",
      "tool": "terminal",
      "command": "qpdf --empty --pages $input_files -- $output_file && echo '合并完成：$output_file'",
      "on_error": "abort",
      "retry": 1
    },
    {
      "id": "step_2_gs",
      "name": "使用 ghostscript 合并 PDF",
      "description": "备选方案：用 ghostscript 合并",
      "tool": "terminal",
      "command": "gs -dBATCH -dNOPAUSE -q -sDEVICE=pdfwrite -sOutputFile=$output_file $input_files && echo '合并完成：$output_file'",
      "on_error": "abort",
      "retry": 0
    },
    {
      "id": "step_3",
      "name": "验证输出",
      "description": "检查输出文件大小",
      "tool": "terminal",
      "command": "ls -lh $output_file",
      "on_error": "continue",
      "retry": 0
    }
  ],
  "version": "1.0",
  "source": "built-in"
}
