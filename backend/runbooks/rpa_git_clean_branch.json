{
  "id": "rpa_git_clean_branch",
  "name": "Git 清理并切换分支",
  "description": "暂存当前改动、拉取最新代码、切换到指定分支并更新依赖",
  "category": "development",
  "tags": ["git", "branch", "clean", "pull"],
  "version": "1.0.0",
  "author": "MaxAgent",
  "source": "builtin",
  "inputs": {
    "branch": {
      "type": "string",
      "description": "目标分支名称",
      "default": "main"
    },
    "project_path": {
      "type": "string",
      "description": "项目根目录",
      "default": "."
    }
  },
  "steps": [
    {
      "id": "step_1",
      "description": "暂存未提交的改动",
      "tool": "terminal",
      "args": {
        "action": "execute",
        "command": "cd {{inputs.project_path}} && git stash"
      },
      "on_error": "continue"
    },
    {
      "id": "step_2",
      "description": "拉取远端最新代码",
      "tool": "terminal",
      "args": {
        "action": "execute",
        "command": "cd {{inputs.project_path}} && git fetch --all"
      },
      "retry": 2,
      "on_error": "abort"
    },
    {
      "id": "step_3",
      "description": "切换到目标分支",
      "tool": "terminal",
      "args": {
        "action": "execute",
        "command": "cd {{inputs.project_path}} && git checkout {{inputs.branch}} && git pull origin {{inputs.branch}}"
      },
      "on_error": "abort"
    }
  ]
}
