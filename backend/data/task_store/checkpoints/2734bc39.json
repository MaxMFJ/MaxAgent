12px;\n            border: 2px solid var(--accent-gold);\n            border-radius: 6px;\n            font-family: inherit;\n            font-size: 1em;\n        }\n\n        .chat-send {\n            padding: 12px 25px;\n            background: var(--accent-red);\n            color: var(--accent-gold);\n            border: 2px solid var(--accent-gold);\n            border-radius: 6px;\n            font-family: inherit;\n            cursor: pointer;\n        }\n\n        .chat-send:hover {\n            background: #5a1515;\n        }\n\n        .chat-send:disabled {\n            opacity: 0.6;\n            cursor: not-allowed;\n        }\n\n        .connection-status {\n            display: inline-block;\n            padding: 3px 10px;\n            border-radius: 12px;\n            font-size: 0.8em;\n            margin-left: 10px;\n        }\n\n        .connection-status.connected {\n            background: #d4edda;\n            color: #155724;\n        }\n\n        .connection-status.disconnected {\n            background: #f8d7da;\n            color: #721c24;\n        }\n\n        /* 响应式 */\n        @media (max-width: 600px) {\n            .header h1 {\n                font-size: 1.6em;\n                letter-spacing: 4px;\n            }\n            \n            .story-content {\n                padding: 20px;\n                font-size: 1em;\n            }\n            \n            .options-container {\n                padding: 20px;\n            }\n            \n            .control-btn {\n                padding: 10px 18px;\n                font-size: 0.9em;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"game-container\">\n        <div class=\"header\">\n            <h1>崂山道士</h1>\n            <div class=\"chapter-title\" id=\"chapterTitle\">序章 · 初上山</div>\n        </div>\n\n        <div class=\"story-content\" id=\"storyContent\">\n            <div class=\"story-text\" id=\"storyText\"></div>\n            <span class=\"cursor\" id=\"cursor\"></span>\n        </div>\n\n        <div class=\"options-container\" id=\"optionsContainer\">\n            <div class=\"options-label\">▼ 请作出选择 ▼</div>\n            <div class=\"options\" id=\"options\"></div>\n        </div>\n\n        <div class=\"chat-panel\" id=\"chatPanel\">\n            <div class=\"chat-messages\" id=\"chatMessages\"></div>\n            <div class=\"chat-input-area\">\n                <input type=\"text\" class=\"chat-input\" id=\"chatInput\" placeholder=\"与道士对话...\" />\n                <button class=\"chat-send\" id=\"chatSend\">发送</button>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button class=\"control-btn\" id=\"settingsBtn\">⚙️ API设置</button>\n            <button class=\"control-btn\" id=\"chatBtn\">💬 与道士论道</button>\n            <button class=\"control-btn\" id=\"restartBtn\">🔄 重新开始</button>\n        </div>\n    </div>\n\n    <!-- API 设置模态框 -->\n    <div class=\"modal\" id=\"settingsModal\">\n        <div class=\"modal-content\">\n            <div class=\"modal-title\">🔧 API 配置</div>\n            <div class=\"form-group\">\n                <label>Base URL</label>\n                <input type=\"text\" id=\"baseUrl\" placeholder=\"https://api.deepseek.com/v1\" />\n            </div>\n            <div class=\"form-group\">\n                <label>API Key</label>\n                <input type=\"password\" id=\"apiKey\" placeholder=\"sk-xxxxxxxx\" />\n            </div>\n            <div class=\"form-group\">\n                <label>模型</label>\n                <select id=\"modelSelect\">\n                    <option value=\"deepseek-chat\">DeepSeek Chat</option>\n                    <option value=\"gpt-3.5-turbo\">GPT-3.5 Turbo</option>\n                    <option value=\"gpt-4\">GPT-4</option>\n                    <option value=\"claude-3-sonnet\">Claude 3 Sonnet</option>\n                </select>\n            </div>\n            <button class=\"modal-btn secondary\" id=\"testConnection\" style=\"width: 100%; margin-bottom: 10px;\">测试连接</button>\n            <div class=\"status-msg\" id=\"statusMsg\"></div>\n            <div class=\"modal-buttons\">\n                <button class=\"modal-btn secondary\" id=\"cancelSettings\">取消</button>\n                <button class=\"modal-btn primary\" id=\"saveSettings\">保存</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // 游戏数据\n        const gameData = {\n            currentChapter: 0,\n            favorability: 50, // 好感度 0-100\n            hasLearnedSpell: false,\n            \n            chapters: [\n                {\n                    title: \"序章 · 初上山\",\n                    content: `县里有位王生，排行第七，乃是官宦人家的子弟。他自幼便羡慕道术，常常想象着能够腾云驾雾、呼风唤雨。\n\n一日，王生听闻崂山上仙人众多，道法玄妙，便背上行囊，决定前往寻仙访道。\n\n崂山高耸入云，山路崎岖。王生跋涉数日，终于登上一座山顶，远远望见一所道观掩映在松柏之间。\n\n「此处必有仙人！」王生心中大喜，整了整衣冠，朝道观走去。`,\n                    options: [\n                        { text: \"整理衣冠，恭敬求见\", next: 1, favorChange: 10 },\n                        { text: \"直接闯入道观\", next: 2, favorChange: -10 }\n                    ]\n                },\n                {\n                    title: \"第一章 · 拜师学艺\",\n                    content: `道观中，一位白发道士盘膝坐在蒲团上，满头银丝垂落肩头，然则目光炯炯有神，神采飞扬。\n\n王生上前恭恭敬敬地行礼道：「在下久闻崂山有仙人，今日得见，三生有幸。恳请仙师收我为徒！」\n\n道士睁开眼，打量了王生一番，缓缓说道：「修仙之路艰苦异常，需能吃苦才行。你这细皮嫩肉的，恐怕受不了那份罪啊。」`,\n                    options: [\n                        { text: \"恳请仙师收留，我吃得了苦\", next: 3, favorChange: 15 },\n                        { text: \"弟子家中略有资产，愿供奉道观\", next: 3, favorChange: 5 },\n                        { text: \"转身离去，另寻他处\", next: 4, favorChange: 0 }\n                    ]\n                },\n                {\n                    title: \"第二章 · 观中修练\",\n           \n\n[分段提示] 共 29294 字符，已读 0–15000。若需后续内容可 read_file offset=15000 limit=15000",
