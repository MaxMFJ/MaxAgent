        "content": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>饮食管理 - 健康生活从每一餐开始</title>\n    <link rel=\"stylesheet\" href=\"style.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n</head>\n<body>\n    <div class=\"app-container\">\n        <!-- 顶部导航 -->\n        <header class=\"header\">\n            <div class=\"header-content\">\n                <div class=\"logo\">\n                    <i class=\"fas fa-leaf\"></i>\n                    <span>饮食管理</span>\n                </div>\n                <div class=\"header-right\">\n                    <div class=\"date-display\">\n                        <i class=\"far fa-calendar-alt\"></i>\n                        <span id=\"currentDate\"></span>\n                    </div>\n                    <button class=\"history-btn\" id=\"historyBtn\">\n                        <i class=\"fas fa-history\"></i>\n                        <span>历史记录</span>\n                    </button>\n                </div>\n            </div>\n        </header>\n\n        <!-- 主内容区 -->\n        <main class=\"main-content\">\n            <!-- 左侧/上方：今日饮食记录 -->\n            <section class=\"diet-section\">\n                <div class=\"section-header\">\n                    <h2><i class=\"fas fa-utensils\"></i> 今日饮食记录</h2>\n                    <div class=\"total-calories\">\n                        <span class=\"label\">今日总计</span>\n                        <span class=\"value\" id=\"todayTotalCalories\">0</span>\n                        <span class=\"unit\">千卡</span>\n                    </div>\n                </div>\n\n                <div class=\"meal-cards\">\n                    <!-- 早餐 -->\n                    <div class=\"meal-card\" data-meal=\"breakfast\">\n                        <div class=\"meal-header\">\n                            <div class=\"meal-icon breakfast\">\n                                <i class=\"fas fa-sun\"></i>\n                            </div>\n                            <div class=\"meal-info\">\n                                <h3>早餐</h3>\n                                <span class=\"meal-time\">7:00 - 9:00</span>\n                            </div>\n                            <div class=\"meal-calories\">\n                                <span class=\"value\" id=\"breakfastCalories\">0</span>\n                                <span class=\"unit\">千卡</span>\n                            </div>\n                        </div>\n                        <div class=\"food-list\" id=\"breakfastFoodList\">\n                            <div class=\"empty-state\">\n                                <i class=\"fas fa-plus-circle\"></i>\n                                <span>点击添加早餐</span>\n                            </div>\n                        </div>\n                        <button class=\"add-food-btn\" data-meal=\"breakfast\">\n                            <i class=\"fas fa-plus\"></i> 添加食物\n                        </button>\n                    </div>\n\n                    <!-- 午餐 -->\n                    <div class=\"meal-card\" data-meal=\"lunch\">\n                        <div class=\"meal-header\">\n                            <div class=\"meal-icon lunch\">\n                                <i class=\"fas fa-cloud-sun\"></i>\n                            </div>\n                            <div class=\"meal-info\">\n                                <h3>午餐</h3>\n                                <span class=\"meal-time\">11:00 - 13:00</span>\n                            </div>\n                            <div class=\"meal-calories\">\n                                <span class=\"value\" id=\"lunchCalories\">0</span>\n                                <span class=\"unit\">千卡</span>\n                            </div>\n                        </div>\n                        <div class=\"food-list\" id=\"lunchFoodList\">\n                            <div class=\"empty-state\">\n                                <i class=\"fas fa-plus-circle\"></i>\n                                <span>点击添加午餐</span>\n                            </div>\n                        </div>\n                        <button class=\"add-food-btn\" data-meal=\"lunch\">\n                            <i class=\"fas fa-plus\"></i> 添加食物\n                        </button>\n                    </div>\n\n                    <!-- 晚餐 -->\n                    <div class=\"meal-card\" data-meal=\"dinner\">\n                        <div class=\"meal-header\">\n                            <div class=\"meal-icon dinner\">\n                                <i class=\"fas fa-moon\"></i>\n                            </div>\n                            <div class=\"meal-info\">\n                                <h3>晚餐</h3>\n                                <span class=\"meal-time\">17:00 - 19:00</span>\n                            </div>\n                            <div class=\"meal-calories\">\n                                <span class=\"value\" id=\"dinnerCalories\">0</span>\n                                <span class=\"unit\">千卡</span>\n                            </div>\n                        </div>\n                        <div class=\"food-list\" id=\"dinnerFoodList\">\n                            <div class=\"empty-state\">\n                                <i class=\"fas fa-plus-circle\"></i>\n                                <span>点击添加晚餐</span>\n                            </div>\n                        </div>\n                        <button class=\"add-food-btn\" data-meal=\"dinner\">\n                            <i class=\"fas fa-plus\"></i> 添加食物\n                        </button>\n                    </div>\n\n                    <!-- 加餐 -->\n                    <div class=\"meal-card\" data-meal=\"snack\">\n                        <div class=\"meal-header\">\n                            <div class=\"meal-icon snack\">\n                                <i class=\"fas fa-cookie-bite\"></i>\n                            </div>\n                            <div class=\"meal-info\">\n                                <h3>加餐</h3>\n                                <span class=\"meal-time\">任意时间</span>\n                            </div>\n                            <div class=\"meal-calories\">\n                                <span class=\"value\" id=\"snackCalories\">0</span>\n                                <span class=\"unit\">千卡</span>\n                            </div>\n                        </div>\n                        <div class=\"food-list\" id=\"snackFoodList\">\n                            <div class=\"empty-state\">\n                                <i class=\"fas fa-plus-circle\"></i>\n                                <span>点击添加加餐</span>\n                            </div>\n                        </div>\n                        <button class=\"add-food-btn\" data-meal=\"snack\">\n                            <i class=\"fas fa-plus\"></i> 添加食物\n                        </button>\n                    </div>\n                </div>\n            </section>\n\n            <!-- 右侧/下方：统计与工具 -->\n            <aside class=\"sidebar\">\n                <!-- 目标设置卡片 -->\n                <div class=\"card goal-card\">\n                    <div class=\"card-header\">\n                        <h3><i class=\"fas fa-bullseye\"></i> 每日目标</h3>\n                        <button class=\"edit-btn\" id=\"editGoalBtn\">\n                            <i class=\"fas fa-edit\"></i>\n                        </button>\n                    </div>\n                    <div class=\"goal-content\">\n                        <div class=\"goal-ring\">\n                            <svg viewBox=\"0 0 120 120\">\n                                <circle class=\"ring-bg\" cx=\"60\" cy=\"60\" r=\"54\"></circle>\n                                <circle class=\"ring-progress\" id=\"goalRing\" cx=\"60\" cy=\"60\" r=\"54\"></circle>\n                            </svg>\n                            <div class=\"goal-text\">\n                                <span class=\"remaining\" id=\"remainingCalories\">2000</span>\n                                <span class=\"label\">剩余千卡</span>\n                            </div>\n                        </div>\n                        <div class=\"goal-stats\">\n                            <div class=\"stat\">\n                                <span class=\"stat-label\">目标</span>\n                                <span class=\"stat-value\" id=\"targetCalories\">2000</span>\n                            </div>\n                            <div class=\"stat\">\n                                <span class=\"stat-label\">已摄入</span>\n                                <span class=\"stat-value\" id=\"consumedCalories\">0</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- 营养统计卡片 -->\n                <div class=\"card nutrition-card\">\n                    <div class=\"card-header\">\n                        <h3><i class=\"fas fa-chart-pie\"></i> 营养成分</h3>\n                    </div>\n                    <div class=\"nutrition-content\">\n                        <div class=\"nutrition-item\">\n                            <div class=\"nutrition-header\">\n                                <span class=\"nutrition-name\">蛋白质</span>\n                                <span class=\"nutrition-value\"><span id=\"proteinValue\">0</span>g</span>\n                            </div>\n                            <div class=\"progress-bar\">\n                                <div class=\"progress protein\" id=\"proteinBar\"></div>\n                            </div>\n                            <span class=\"nutrition-percent\" id=\"proteinPercent\">0%</span>\n                        </div>\n                        <div class=\"nutrition-item\">\n                            <div class=\"nutrition-header\">\n                                <span class=\"nutrition-name\">碳水化合物</span>\n                                <span class=\"nutrition-value\"><span id=\"carbsValue\">0</span>g</span>\n                            </div>\n                            <div class=\"progress-bar\">\n                                <div class=\"progress carbs\" id=\"carbsBar\"></div>\n                            </div>\n                            <span class=\"nutrition-percent\" id=\"carbsPercent\">0%</span>\n                        </div>\n                        <div class=\"nutrition-item\">\n                            <div class=\"nutrition-header\">\n                                <span class=\"nutrition-name\">脂肪</span>\n                                <span class=\"nutrition-value\"><span id=\"fatValue\">0</span>g</span>\n                            </div>\n                            <div class=\"progress-bar\">\n                                <div class=\"progress fat\" id=\"fatBar\"></div>\n                            </div>\n                            <span class=\"nutrition-percent\" id=\"fatPercent\">0%</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- 快速添加卡片 -->\n                <div class=\"card quick-add-card\">\n                    <div class=\"card-header\">\n                        <h3><i class=\"fas fa-search\"></i> 食物库</h3>\n                    </div>\n                    <div class=\"search-box\">\n                        <input type=\"text\" id=\"foodSearch\" placeholder=\"搜索食物...\">\n                        <i class=\"fas fa-search\"></i>\n                    </div>\n                    <div class=\"food-library\" id=\"foodLibrary\">\n                        <!-- 食物列表将通过JS动态生成 -->\n                    </div>\n                </div>\n            </aside>\n        </main>\n    </div>\n\n    <!-- 添加食物弹窗 -->\n    <div class=\"modal\" id=\"addFoodModal\">\n        <div class=\"modal-overlay\"></div>\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h3>添加食物</h3>\n                <button class=\"close-btn\" id=\"closeModal\">\n                    <i class=\"fas fa-times\"></i>\n                </button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"form-group\">\n                    <label>食物名称</label>\n                    <input type=\"text\" id=\"foodName\" placeholder=\"输入食物名称\">\n                </div>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label>卡路里 (千卡)</label>\n                        <input type=\"number\" id=\"foodCalories\" placeholder=\"0\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>份量</label>\n                        <input type=\"number\" id=\"foodAmount\" placeholder=\"1\" value=\"1\">\n                    </div>\n                </div>\n                <div class=\"form-row\">\n                    <div class=\"form-group\">\n                        <label>蛋白质</label>\n                        <input type=\"number\" id=\"foodProtein\" placeholder=\"0\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>碳水</label>\n                        <input type=\"number\" id=\"foodCarbs\" placeholder=\"0\">\n                    </div>\n                    <div class=\"form-group\">\n                        <label>脂肪</label>\n                        <input type=\"number\" id=\"foodFat\" placeholder=\"0\">\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button class=\"btn btn-secondary\" id=\"cancelAdd\">取消</button>\n                <button class=\"btn btn-primary\" id=\"confirmAdd\">确认添加</button>\n            </div>\n        </div>\n    </div>\n\n    <!-- 目标设置弹窗 -->\n    <div class=\"modal\" id=\"goalModal\">\n        <div class=\"modal-overlay\"></div>\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h3>设置每日目标</h3>\n                <button class=\"close-btn\" id=\"closeGoalModal\">\n                    <i class=\"fas fa-times\"></i>\n                </button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"form-group\">\n                    <label>每日卡路里目标</label>\n                    <input type=\"number\" id=\"goalCalories\" placeholder=\"2000\">\n                </div>\n                <div class=\"preset-goals\">\n                    <button class=\"preset-btn\" data-calories=\"1500\">减肥 1500</button>\n                    <button class=\"preset-btn\" data-calories=\"2000\">标准 2000</button>\n                    <button class=\"preset-btn\" data-calories=\"2500\">增肌 2500</button>\n                </div>\n            </div>\n            <div class=\"modal-footer\">\n                <button class=\"btn btn-secondary\" id=\"cancelGoal\">取消</button>\n                <button class=\"btn btn-primary\" id=\"confirmGoal\">确认</button>\n            </div>\n        </div>\n    </div>\n\n    <!-- 历史记录弹窗 -->\n    <div class=\"modal\" id=\"historyModal\">\n        <div class=\"modal-overlay\"></div>\n        <div class=\"modal-content history-modal\">\n            <div class=\"modal-header\">\n                <h3>历史记录</h3>\n                <button class=\"close-btn\" id=\"closeHistoryModal\">\n                    <i class=\"fas fa-times\"></i>\n                </button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"history-chart\">\n                    <canvas id=\"historyChart\"></canvas>\n                </div>\n                <div class=\"history-list\" id=\"historyList\">\n                    <!-- 历史记录将通过JS动态生成 -->\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <!-- Toast 提示 -->\n    <div class=\"toast\" id=\"toast\">\n        <i class=\"fas fa-check-circle\"></i>\n        <span id=\"toastMessage\"></span>\n    </div>\n\n    <script src=\"script.js\"></script>\n</body>\n</html>"
