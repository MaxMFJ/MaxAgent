{
  "id": "capsule_open_app_with_fallback",
  "description": "打开应用程序，失败时通过终端命令回退打开",
  "version": "1.0.0",
  "inputs": {
    "app_name": {
      "type": "string",
      "description": "应用名称，如 Safari、微信、VSCode"
    }
  },
  "outputs": {
    "result": {
      "type": "object",
      "description": "打开结果"
    }
  },
  "procedure": [
    {
      "id": "open_app",
      "type": "tool",
      "tool": "app",
      "args": {
        "action": "open",
        "app_name": "{{input.app_name}}"
      },
      "retry": 1,
      "retry_delay": 2.0,
      "timeout": 15,
      "fallback_tool": "terminal",
      "fallback_args": {
        "command": "open -a '{{input.app_name}}'"
      }
    },
    {
      "id": "verify",
      "type": "tool",
      "tool": "app",
      "args": {
        "action": "list"
      },
      "condition": "{{output.open_app.success}} == true"
    }
  ],
  "task_type": "app_control",
  "tags": ["app", "open", "打开", "应用", "启动"],
  "capability": ["app_control", "app_launch"],
  "priority": 1,
  "schema_version": "1.1.0"
}
